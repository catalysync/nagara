# nagara environment template.
# Copy to .env and fill in values for local dev. NEVER commit a real .env.
#
# Every variable has a sensible default in src/nagara/config.py — only set
# the ones you need to override.

# ── App ─────────────────────────────────────────────────────────────────
# Selects which .env file is loaded and switches behavior helpers.
# One of: development | test | staging | production
NAGARA_ENV=development

# Logging level for the app (matches Python logging values).
NAGARA_LOG_LEVEL=INFO

# ── Security (REQUIRED in production) ──────────────────────────────────
# Used to sign sessions, JWTs, etc. In production, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Empty string here means "unset" — verify_settings() will reject it in prod.
NAGARA_SECRET_KEY=

# ── HTTP ────────────────────────────────────────────────────────────────
# Public-facing base URL. Used to build absolute links in emails, webhooks, etc.
NAGARA_BASE_URL=http://127.0.0.1:8000

# Frontend URL — used by the API to redirect after auth flows.
NAGARA_FRONTEND_BASE_URL=http://127.0.0.1:3000

# Comma-separated list of allowed CORS origins. Empty = none.
# Pydantic settings parses JSON arrays for list fields:
#   NAGARA_CORS_ORIGINS=["http://localhost:3000"]
NAGARA_CORS_ORIGINS=[]

# Optional regex matched against the Origin header (in addition to the list above).
# Useful for ephemeral preview hosts.
# NAGARA_CORS_ORIGIN_REGEX=

# Allow cookies/auth on cross-origin requests. Cannot combine with "*" origin.
# NAGARA_CORS_ALLOW_CREDENTIALS=false

# Trust X-Forwarded-* headers from an upstream reverse proxy. Only enable when
# the proxy strips these from client requests (otherwise spoofable).
# NAGARA_TRUST_PROXY=false

# Reject requests whose Content-Length exceeds this many bytes with 413.
# NAGARA_REQUEST_MAX_BYTES=10485760

# How often the request-cancel middleware checks for client disconnect.
# NAGARA_REQUEST_CANCEL_POLL_SECONDS=0.1

# ── Database ────────────────────────────────────────────────────────────
# Override the assembled DSN entirely (Render/Heroku/Supabase typically
# inject DATABASE_URL — both NAGARA_DATABASE_URL and DATABASE_URL work).
# DATABASE_URL=postgresql+asyncpg://user:pwd@host:5432/dbname

# Or set the parts and we'll assemble the DSN at runtime.
NAGARA_POSTGRES_USER=nagara
NAGARA_POSTGRES_PWD=nagara
NAGARA_POSTGRES_HOST=127.0.0.1
NAGARA_POSTGRES_PORT=5432
NAGARA_POSTGRES_DB=nagara

# Minimum supported Postgres major version. Boot fails if the server reports
# a lower version. Set to 0 to disable the check.
# NAGARA_POSTGRES_MIN_VERSION=15

# Pool tuning. Defaults are reasonable for a single-process dev app.
# NAGARA_DATABASE_POOL_SIZE=5
# NAGARA_DATABASE_POOL_RECYCLE_SECONDS=600
# NAGARA_DATABASE_COMMAND_TIMEOUT_SECONDS=30

# ── Redis ───────────────────────────────────────────────────────────────
# Used by the rate limiter.
# NAGARA_REDIS_URL=redis://127.0.0.1:6379/0

# ── Observability ───────────────────────────────────────────────────────
# Sentry DSN. No-op when unset.
# NAGARA_SENTRY_DSN=

# Release version reported by /health endpoints (commit SHA / git tag).
# NAGARA_RELEASE_VERSION=dev

# ── Sessions ───────────────────────────────────────────────────────────
# How long a user session lasts before requiring re-auth.
# Pydantic parses this as a timedelta (e.g., "P31D" / "31 days").
# NAGARA_USER_SESSION_TTL=31 days

# ── Profile (optional, CLI feature) ─────────────────────────────────────
# Selects an active profile from ~/.config/nagara/profiles.toml
# (only applies if you've set up profiles via the CLI).
# NAGARA_PROFILE=dev
