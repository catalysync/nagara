# Test-suite environment. Loaded by src/nagara/config.py when
# NAGARA_ENV=test (e.g., ``NAGARA_ENV=test pytest``).

NAGARA_ENV=test
NAGARA_LOG_LEVEL=WARNING

# Deterministic signing key. 32+ chars to satisfy production-grade
# secret-length checks even though we're in test.
NAGARA_SECRET_KEY=test-secret-not-for-production-use-32chars

NAGARA_BASE_URL=http://127.0.0.1:8000
NAGARA_FRONTEND_BASE_URL=http://127.0.0.1:3000
NAGARA_CORS_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]

# Separate DB so a botched test run can never trash dev data. The
# matching database needs to exist; create it with
#   createdb -h 127.0.0.1 -U nagara nagara_test
# or let CI run ``just createdb-test``.
NAGARA_POSTGRES_USER=nagara
NAGARA_POSTGRES_PWD=nagara
NAGARA_POSTGRES_HOST=127.0.0.1
NAGARA_POSTGRES_PORT=5432
NAGARA_POSTGRES_DB=nagara_test
